#!/usr/bin/env bash
# Commander SDR — git pre-commit gate
#
# Closes GOVERNANCE_MAP gap G-07 (commit-time enforcement). Kiro hooks have
# no native git pre-commit event, so this script provides the commit-time
# conformance subset that complements the Kiro hooks layer.
#
# Activation (run once per clone):
#     git config core.hooksPath .githooks
#
# Behaviour:
# - Reads the staged files for the pending commit (no working-tree scans).
# - Refuses the commit on any HARD violation; prints the violation and the
#   reference assertion / authority document.
# - Exits 0 on clean; non-zero on any violation.
# - Does not modify files. Author corrects manually.
#
# Authority:
# - docs/knowledge/SOURCING_RULE.md (locked)
# - .kiro/testing/conformance-registry.md (SEC-001 hardcoded secrets)
# - docs/knowledge/ARCHITECTURAL_DEBT_REGISTER.md ARCH-DEBT-001
#
# Implementation note: portable Bash + grep only. Works on Git Bash on
# Windows, macOS, and Linux. Uses BSD-compatible grep syntax where possible.

set -uo pipefail

# Colours (best-effort; honoured if terminal supports them).
if [[ -t 2 ]]; then
    RED=$'\e[31m'
    YEL=$'\e[33m'
    GRN=$'\e[32m'
    DIM=$'\e[2m'
    OFF=$'\e[0m'
else
    RED=''; YEL=''; GRN=''; DIM=''; OFF=''
fi

violations=0

# Helper — record a violation.
flag() {
    local rule="$1"; shift
    local file="$1"; shift
    local message="$*"
    printf '%s[FAIL]%s %s — %s\n         %s%s%s\n' \
        "$RED" "$OFF" "$rule" "$file" "$DIM" "$message" "$OFF" >&2
    violations=$((violations + 1))
}

note() {
    local rule="$1"; shift
    local file="$1"; shift
    local message="$*"
    printf '%s[FLAG]%s %s — %s\n         %s%s%s\n' \
        "$YEL" "$OFF" "$rule" "$file" "$DIM" "$message" "$OFF" >&2
}

# Files staged for this commit (Added, Copied, Modified, Renamed; ignore Deletions).
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

if [[ -z "${staged_files:-}" ]]; then
    # Nothing to check (e.g. empty commit or only deletions).
    exit 0
fi

# Iterate each staged file. Read the staged version (`git show :file`) rather
# than the working-tree copy so we check what is actually being committed.
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    [[ ! -f "$file" ]] && continue

    # Skip the script itself, the conformance registry, and known meta-files
    # that legitimately reference forbidden patterns as documentation.
    case "$file" in
        .githooks/pre-commit) continue ;;
        .kiro/testing/conformance-registry.md) continue ;;
        .kiro/hooks/README.md) continue ;;
        .kiro/hooks/*.kiro.hook) continue ;;
        .kiro/hooks/*-hook.md) continue ;;
        .kiro/hooks/*-hook.json) continue ;;
        .kiro/steering/*.md) continue ;;
        docs/knowledge/SOURCING_RULE.md) continue ;;
        docs/knowledge/BASELINE_SOURCE_INVENTORY.md) continue ;;
        docs/knowledge/HOOK_RECONCILIATION.md) continue ;;
        docs/knowledge/ARCHITECTURAL_DEBT_REGISTER.md) continue ;;
        docs/knowledge/ARCHITECTURAL_FINDINGS.md) continue ;;
        docs/knowledge/RELATIONSHIP_MAP.md) continue ;;
        docs/knowledge/COVERAGE.md) continue ;;
        docs/knowledge/SALVAGE_AND_REBASELINE_REGISTER.md) continue ;;
        docs/knowledge/GOVERNANCE_MAP.md) continue ;;
        docs/knowledge/GOVERNANCE_BUILD_INVENTORY.md) continue ;;
        docs/knowledge/_superseded/*) continue ;;
        docs/99_source_archive/*) continue ;;
    esac

    # Pull the staged blob; on read failure just skip and warn.
    blob=$(git show ":$file" 2>/dev/null) || continue

    # ----------------------------------------------------------------
    # CHECK 1 — Translation-layer citation in knowledge / authority /
    #           build-pack / rebaseline files.
    # ----------------------------------------------------------------
    case "$file" in
        docs/knowledge/*|docs/00_authority/*|docs/04_build_packs/*|docs/02_architecture/*|DECISIONS.md|BUILD_SEQUENCE.md|BUILD_VERSION_ROADMAP.md|SALVAGE_AND_REBASELINE_REGISTER.md)
            if printf '%s' "$blob" | grep -nE '\.kiro/specs/' >/dev/null 2>&1; then
                # Be precise — show line numbers.
                matches=$(printf '%s' "$blob" | grep -nE '\.kiro/specs/' | head -3)
                flag "ARCH-DEBT-001" "$file" \
                    "Citation to '.kiro/specs/' translation layer detected. Re-point to baseline #N filename in docs/99_source_archive/baseline_v2_6_2/. Authority: docs/knowledge/SOURCING_RULE.md."
                printf '         %s%s%s\n' "$DIM" "$(printf '%s\n' "$matches" | sed 's/^/         /' | head -3)" "$OFF" >&2
            fi
            ;;
    esac

    # ----------------------------------------------------------------
    # CHECK 2 — Forbidden source citations in docs/knowledge/.
    #           Beyond the translation layer, also flag derived sources.
    # ----------------------------------------------------------------
    case "$file" in
        docs/knowledge/*)
            if printf '%s' "$blob" | grep -nE 'docs/02_architecture/source_|docs/05_design_reference/source_' >/dev/null 2>&1; then
                matches=$(printf '%s' "$blob" | grep -nE 'docs/02_architecture/source_|docs/05_design_reference/source_' | head -3)
                flag "SOURCING_RULE" "$file" \
                    "Citation to derived source-copy file (docs/02_architecture/source_* or docs/05_design_reference/source_*). Re-point to docs/99_source_archive/baseline_v2_6_2/."
                printf '         %s%s%s\n' "$DIM" "$(printf '%s\n' "$matches" | sed 's/^/         /' | head -3)" "$OFF" >&2
            fi
            ;;
    esac

    # ----------------------------------------------------------------
    # CHECK 3 — Hardcoded secrets (SEC-001).
    #
    # Scans every staged file for high-confidence secret patterns. Conservative
    # by design — false positives create commit pain; better to undermatch and
    # rely on the Kiro postTask hook for deeper checks.
    #
    # Patterns:
    #   - AWS access key IDs:  AKIA[0-9A-Z]{16}
    #   - AWS secret access keys: looks for 40-char base64-ish near a hint
    #   - Private keys: BEGIN ... PRIVATE KEY
    #   - Bearer tokens with JWT shape (three base64url segments)
    # ----------------------------------------------------------------

    # 3a — AWS access key IDs.
    if printf '%s' "$blob" | grep -nE 'AKIA[0-9A-Z]{16}' >/dev/null 2>&1; then
        matches=$(printf '%s' "$blob" | grep -nE 'AKIA[0-9A-Z]{16}' | head -3)
        flag "SEC-001" "$file" \
            "Hardcoded AWS access key ID detected (AKIA…). Use environment variables or secret manager."
        printf '         %s%s%s\n' "$DIM" "$(printf '%s\n' "$matches" | sed 's/^/         /' | head -3)" "$OFF" >&2
    fi

    # 3b — Private key blocks.
    if printf '%s' "$blob" | grep -nE 'BEGIN [A-Z ]*PRIVATE KEY' >/dev/null 2>&1; then
        matches=$(printf '%s' "$blob" | grep -nE 'BEGIN [A-Z ]*PRIVATE KEY' | head -1)
        flag "SEC-001" "$file" \
            "Private key block detected. Private keys must never be committed."
        printf '         %s%s%s\n' "$DIM" "         $matches" "$OFF" >&2
    fi

    # 3c — JWT-shaped bearer tokens hard-coded.
    if printf '%s' "$blob" | grep -nE 'eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}' >/dev/null 2>&1; then
        matches=$(printf '%s' "$blob" | grep -nE 'eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}' | head -1)
        flag "SEC-001" "$file" \
            "JWT-shaped bearer token detected. Tokens must not be committed; use placeholders or env vars."
        printf '         %s%s%s\n' "$DIM" "         $matches" "$OFF" >&2
    fi

    # 3d — Real-looking password / api_key assignments with non-placeholder values.
    #     Restrict to source code files to avoid false positives in markdown.
    case "$file" in
        *.ts|*.tsx|*.js|*.jsx|*.py|*.rb|*.go|*.java|*.cs|*.kt|*.rs|*.php|*.sh)
            if printf '%s' "$blob" | grep -nEi '(api[_-]?key|password|secret)[[:space:]]*[:=][[:space:]]*"[A-Za-z0-9_/+=-]{20,}"' >/dev/null 2>&1; then
                matches=$(printf '%s' "$blob" | grep -nEi '(api[_-]?key|password|secret)[[:space:]]*[:=][[:space:]]*"[A-Za-z0-9_/+=-]{20,}"' | head -2)
                # Check it isn't a placeholder.
                if ! printf '%s' "$matches" | grep -Eqi 'xxxx|example|placeholder|<your|your-key|sample|fake|test|EXAMPLE_' ; then
                    flag "SEC-001" "$file" \
                        "Hardcoded credential-shaped string (api_key/password/secret). If this is an example, use a placeholder (xxxx, EXAMPLE_KEY, <your-key-here>)."
                    printf '         %s%s%s\n' "$DIM" "$(printf '%s\n' "$matches" | sed 's/^/         /')" "$OFF" >&2
                fi
            fi
            ;;
    esac

done <<< "$staged_files"

# ----------------------------------------------------------------
# CHECK 4 — UC-XXX traceability reference in commit message for
#            new entity/engine/page files.
#
# Per traceability-chain.md Rule 5: commits adding new pages,
# entities, or engines MUST include a UC-XXX reference.
# This is a WARNING (not a FAIL) to avoid blocking established
# workflow while governance adoption ramps up.
# ----------------------------------------------------------------

# Detect new (Added) entity, engine, or page files in the staged set.
new_artefacts=$(git diff --cached --name-only --diff-filter=A | grep -E '(packages/contracts/src/entities/.*\.ts$|packages/contracts/src/engines/.*\.ts$|apps/web/src/app/.*/page\.tsx$)' || true)

if [[ -n "$new_artefacts" ]]; then
    commit_msg_file="$PWD/.git/COMMIT_EDITMSG"
    if [[ -f "$commit_msg_file" ]]; then
        commit_msg=$(cat "$commit_msg_file")
    else
        commit_msg=$(git log -1 --format=%B 2>/dev/null || echo "")
    fi
    if ! printf '%s' "$commit_msg" | grep -qE 'UC-[0-9]+'; then
        note "TRACEABILITY" "commit message" \
            "New entity/engine/page staged but commit message has no UC-XXX reference. Per traceability-chain.md Rule 5, add a UC reference."
    fi
fi

# ----------------------------------------------------------------
# CHECK 5 — DATA_DICTIONARY co-staging on new entity files.
# ----------------------------------------------------------------

new_entities=$(git diff --cached --name-only --diff-filter=A | grep -E '^packages/contracts/src/entities/.*\.ts$' || true)

if [[ -n "$new_entities" ]]; then
    if ! echo "$staged_files" | grep -q 'docs/knowledge/DATA_DICTIONARY.md'; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            note "DATA-DICT" "$f" \
                "New entity staged without DATA_DICTIONARY.md update. Per traceability chain hard gate, register entity in DATA_DICTIONARY before or with code."
        done <<< "$new_entities"
    fi
fi

# ----------------------------------------------------------------
# CHECK 6 — RELATIONSHIP_MAP co-staging on new multi-entity pages.
# ----------------------------------------------------------------
# If a new page file is staged that imports from 2+ different entity/fixture paths,
# check that RELATIONSHIP_MAP.md is also staged (or already documents the relationship).
# WARNING only — flags cross-entity pages without documented relationships.

new_pages=$(git diff --cached --name-only --diff-filter=A | grep -E '^apps/web/src/app/.*page\.tsx$' || true)

if [[ -n "$new_pages" ]]; then
    while IFS= read -r page; do
        [[ -z "$page" ]] && continue
        blob=$(git show ":$page" 2>/dev/null) || continue
        import_count=$(printf '%s' "$blob" | grep -cE 'from.*/fixtures/seed-|from.*/entities/' || true)
        if (( import_count > 1 )); then
            if ! echo "$staged_files" | grep -q 'docs/knowledge/RELATIONSHIP_MAP.md'; then
                note "RELATIONSHIP" "$page" \
                    "Multi-entity page staged without RELATIONSHIP_MAP.md update. Per traceability chain, cross-entity relationships must be documented."
            fi
        fi
    done <<< "$new_pages"
fi

# ----------------------------------------------------------------
# CHECK 7 — PAGE_SCHEDULE co-staging on new page files.
# ----------------------------------------------------------------

new_pages_all=$(git diff --cached --name-only --diff-filter=A | grep -E '^apps/web/src/app/.*page\.tsx$' || true)

if [[ -n "$new_pages_all" ]]; then
    if ! echo "$staged_files" | grep -q 'docs/00_authority/PAGE_SCHEDULE.md'; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            note "PAGE-SCHED" "$f" \
                "New page staged without PAGE_SCHEDULE.md update. Per traceability chain, register route in PAGE_SCHEDULE with UC reference."
        done <<< "$new_pages_all"
    fi
fi

# ----------------------------------------------------------------
# CHECK 8 — AICAP_REGISTER co-staging for pages with AI-PLACEMENT.
# ----------------------------------------------------------------

new_pages_ai=$(git diff --cached --name-only --diff-filter=A | grep -E '^apps/web/src/app/.*page\.tsx$' || true)
if [[ -n "$new_pages_ai" ]]; then
    while IFS= read -r page; do
        [[ -z "$page" ]] && continue
        blob=$(git show ":$page" 2>/dev/null) || continue
        if printf '%s' "$blob" | grep -q 'AI-PLACEMENT'; then
            if ! echo "$staged_files" | grep -q 'docs/00_authority/AICAP_REGISTER.md'; then
                note "AICAP" "$page" \
                    "Page with AI-PLACEMENT marker but AICAP_REGISTER.md not staged. Update register."
            fi
        fi
    done <<< "$new_pages_ai"
fi

# ----------------------------------------------------------------
# CHECK 9 — SYSTEM_KNOWLEDGE_GRAPH co-staging for new entities.
# ----------------------------------------------------------------

new_ents_graph=$(git diff --cached --name-only --diff-filter=A | grep -E '^packages/contracts/src/entities/.*\.ts$' || true)
if [[ -n "$new_ents_graph" ]]; then
    if ! echo "$staged_files" | grep -q 'docs/knowledge/SYSTEM_KNOWLEDGE_GRAPH.md'; then
        note "KNOWLEDGE-GRAPH" "new entity" \
            "New entity staged — verify SYSTEM_KNOWLEDGE_GRAPH.md is current. Update if new domain introduced."
    fi
fi

# ----------------------------------------------------------------
# CHECK 10 — DATA_DICTIONARY sync on modified entity files.
# ----------------------------------------------------------------

modified_entities=$(git diff --cached --name-only --diff-filter=M | grep -E '^packages/contracts/src/entities/.*\.ts$' || true)
if [[ -n "$modified_entities" ]]; then
    if ! echo "$staged_files" | grep -q 'docs/knowledge/DATA_DICTIONARY.md'; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            note "DICT-SYNC" "$f" \
                "Entity modified but DATA_DICTIONARY.md not staged. Verify field list is still accurate."
        done <<< "$modified_entities"
    fi
fi

# ----------------------------------------------------------------
# Governance runner (ARCH-008 integrity backstop).
# ----------------------------------------------------------------

if command -v node >/dev/null 2>&1 && [[ -f "$PWD/scripts/governance-check.cjs" ]]; then
    node "$PWD/scripts/governance-check.cjs" --pre-commit 2>&1
    if (( $? != 0 )); then
        violations=$((violations + 1))
    fi
fi

# ----------------------------------------------------------------
# Decision.
# ----------------------------------------------------------------

if (( violations > 0 )); then
    printf '\n%s[REFUSED]%s pre-commit gate found %d violation(s). Address them before retrying the commit.\n' \
        "$RED" "$OFF" "$violations" >&2
    printf '%sReferences:%s\n' "$DIM" "$OFF" >&2
    printf '  - docs/knowledge/SOURCING_RULE.md\n' >&2
    printf '  - .kiro/testing/conformance-registry.md (SEC-001..006, RBAC-001..004)\n' >&2
    printf '  - docs/knowledge/ARCHITECTURAL_DEBT_REGISTER.md (ARCH-DEBT-001)\n' >&2
    printf '  - .kiro/hooks/README.md (commit-time enforcement section)\n' >&2
    exit 1
fi

printf '%s[OK]%s pre-commit gate clean.\n' "$GRN" "$OFF" >&2
exit 0
